# ZDG Agent Firewall
# Copy to .env and adjust before running.
#
# When running via Docker (docker compose up):
#   - ZDG_DB_PATH, ZDG_MAILDIR_PATH, ZDG_WORKSPACE are overridden by
#     docker-compose.yml environment: to container-appropriate paths.
#     You do not need to change those here for container use.
#   - ZDG_ADMIN_TOKEN must be set here (or in the environment) before starting.
#   - ZDG_FILESYSTEM_ALLOWED_ROOTS defaults to [] in the container; set it
#     to a host-mounted path only if you enable ZDG_REAL_EXEC_FILESYSTEM=true.
#
# When running locally (uvicorn directly):
#   - All values below apply as-is.

# Server
ZDG_HOST=127.0.0.1
ZDG_PORT=8000
ZDG_ENV=development

# Database
# Local dev: relative to CWD. Container: overridden to /var/lib/zdg/zdg_firewall.db.
ZDG_DB_PATH=./zdg_firewall.db

# Policy bundle
ZDG_POLICY_BUNDLE_PATH=./policies/bundles/local_default.yaml

# Workspace and filesystem execution
# Local dev: set to a real directory. Container: leave unset (overridden by compose).
ZDG_WORKSPACE=~/workspace
ZDG_FILESYSTEM_ALLOWED_ROOTS=["~/workspace"]
ZDG_FS_READ_APPROVAL_BYTES=10485760

# Approval, idempotency, and repeated-denial risk tuning
ZDG_APPROVAL_EXPIRY_SECONDS=600
ZDG_IDEMPOTENCY_WINDOW_SECONDS=300
ZDG_RISK_BLOCK_COUNT_WINDOW_SECONDS=300
ZDG_RISK_REPEATED_DENIALS_THRESHOLD=3

# Contract TTL
ZDG_CONTRACT_TTL_SECONDS=3600

# Real execution gates — all off by default
ZDG_REAL_EXEC=false
ZDG_REAL_EXEC_FILESYSTEM=false
ZDG_REAL_EXEC_MESSAGING=false
ZDG_REAL_EXEC_SHELL=false
ZDG_REAL_EXEC_HTTP=false

# Messaging execution
# Local dev: ~/.zdg/maildir. Container: overridden to /var/lib/zdg/maildir.
ZDG_MAILDIR_PATH=~/.zdg/maildir

# Shell execution limits
ZDG_SHELL_TIMEOUT_SECONDS=15
ZDG_SHELL_MAX_OUTPUT_BYTES=16384
ZDG_SHELL_ALLOWED_ENV=["PATH","HOME","TMP","TEMP","TMPDIR","LANG","LC_ALL"]

# HTTP execution limits
ZDG_HTTP_TIMEOUT_SECONDS=10.0
ZDG_HTTP_MAX_RESPONSE_BYTES=65536
ZDG_HTTP_MAX_REDIRECTS=3

# Kill switch auto-trigger thresholds
ZDG_KS_SHELL_BLOCK_COUNT=3
ZDG_KS_SHELL_BLOCK_WINDOW=120
ZDG_KS_HTTP_BLOCK_COUNT=10
ZDG_KS_HTTP_BLOCK_WINDOW=300
ZDG_KS_ESCALATE_COUNT=3

# Control-plane auth
# Required for /v1/approvals, /v1/approval/*, /v1/killswitch/*,
# /v1/events, /v1/metrics, /v1/investigate, and /v1/policy/reload.
ZDG_ADMIN_TOKEN=change-me-before-use

# Logging
# Supported: text | json
ZDG_LOG_FORMAT=text

# Audit chain ID (unique per deployment)
ZDG_CHAIN_ID=zdg-local-chain-01

# OpenClaw adapter
OPENCLAW_TOOL_MAP_PATH=./adapters/openclaw/tool_map.yaml
OPENCLAW_ZDG_BASE_URL=http://localhost:8000
OPENCLAW_ZDG_TIMEOUT=5
OPENCLAW_FAIL_MODE=closed
OPENCLAW_AGENT_ID_FIELD=assistant_id
OPENCLAW_VERSION=2026-03

# ── Licensing ──────────────────────────────────────────────────────────────────
# ZDG-FR Developer Edition supports a lightweight licensing layer.
# Canonical plan codes: free | dev_monthly | dev_annual
#
# No license registered = unmanaged mode (all features accessible, no enforcement).
# This is the default for new installations. No action required to start evaluating.
#
# To activate a license after startup:
#   curl -s -X POST http://127.0.0.1:8000/v1/license/activate \
#     -H "X-ZDG-Admin-Token: $ZDG_ADMIN_TOKEN" \
#     -H "Content-Type: application/json" \
#     -d '{"email":"you@example.com","plan_code":"dev_monthly"}'
#
# To check current license status:
#   curl -s http://127.0.0.1:8000/v1/license -H "X-ZDG-Admin-Token: $ZDG_ADMIN_TOKEN"
#
# To browse plan definitions and default entitlements:
#   curl -s http://127.0.0.1:8000/v1/license/plans -H "X-ZDG-Admin-Token: $ZDG_ADMIN_TOKEN"

# ── Stripe Billing (PAY-01) ────────────────────────────────────────────────────
# Leave all STRIPE_* values empty to run without Stripe (billing routes return 503).
# Required for paid subscriptions:
#   - STRIPE_SECRET_KEY: your Stripe secret key (sk_live_... or sk_test_...)
#   - STRIPE_WEBHOOK_SECRET: from Stripe Dashboard → Webhooks → Signing secret (whsec_...)
#   - STRIPE_PRICE_ID_DEV_MONTHLY: Stripe price ID for the dev_monthly plan
#   - STRIPE_PRICE_ID_DEV_ANNUAL: Stripe price ID for the dev_annual plan
#
# Webhook events to enable in Stripe Dashboard:
#   checkout.session.completed
#   customer.subscription.updated
#   customer.subscription.deleted
#   invoice.payment_failed
#
# Webhook endpoint URL:
#   https://<your-host>/v1/billing/webhook
#
# To start a checkout session (admin only):
#   curl -s -X POST http://127.0.0.1:8000/v1/billing/checkout \
#     -H "X-ZDG-Admin-Token: $ZDG_ADMIN_TOKEN" \
#     -H "Content-Type: application/json" \
#     -d '{"account_id": "acc_...", "plan_code": "dev_monthly"}'
#
# To open the billing management portal:
#   curl -s -X POST http://127.0.0.1:8000/v1/billing/portal \
#     -H "X-ZDG-Admin-Token: $ZDG_ADMIN_TOKEN" \
#     -H "Content-Type: application/json" \
#     -d '{"account_id": "acc_..."}'

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_DEV_MONTHLY=
STRIPE_PRICE_ID_DEV_ANNUAL=
STRIPE_SUCCESS_URL=http://localhost:8000/billing/success
STRIPE_CANCEL_URL=http://localhost:8000/billing/cancel
STRIPE_PORTAL_RETURN_URL=http://localhost:8000/billing
